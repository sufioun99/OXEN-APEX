-- =============================================================================
-- SUFIOUN DATABASE SYSTEM - MASTER SCRIPT (Oracle APEX Optimized)
-- Electronics Sales and Service Management System
-- Contains: 
--   1. Dynamic Teardown (Drops existing objects)
--   2. Schema Creation (Tables, Views, Sequences, Indexes, Triggers, Procedures)
--   3. Test Data Insertion (10 rows per table)
-- =============================================================================

SET SERVEROUTPUT ON;
SET DEFINE OFF;
ALTER SESSION SET NLS_DATE_FORMAT = 'YYYY-MM-DD';

-- =============================================================================
-- PART 1: DYNAMIC TEARDOWN SCRIPT
-- =============================================================================
DECLARE
    CURSOR c_objects IS
        SELECT object_name, object_type
        FROM user_objects
        WHERE object_name LIKE 'SUFIOUN_%'
        AND object_type IN (
          'TABLE',
          'VIEW',
          'SEQUENCE',
          'INDEX',
          'PROCEDURE',
          'FUNCTION',
          'TRIGGER',
          'PACKAGE',
          'PACKAGE BODY'
        )
        ORDER BY
            CASE object_type
                WHEN 'TRIGGER' THEN 1
                WHEN 'PROCEDURE' THEN 2
                WHEN 'FUNCTION' THEN 3
          WHEN 'PACKAGE BODY' THEN 4
          WHEN 'PACKAGE' THEN 5
          WHEN 'VIEW' THEN 6
          WHEN 'INDEX' THEN 7
          WHEN 'TABLE' THEN 8
          WHEN 'SEQUENCE' THEN 9
          ELSE 10
            END;
    v_sql VARCHAR2(500);
BEGIN
    DBMS_OUTPUT.PUT_LINE('Starting dynamic cleanup of SUFIOUN objects...');
    DBMS_OUTPUT.PUT_LINE('------------------------------------------------');

    FOR obj IN c_objects LOOP
        BEGIN
            IF obj.object_type = 'TABLE' THEN
                v_sql := 'DROP TABLE ' || obj.object_name || ' CASCADE CONSTRAINTS';
            ELSE
                v_sql := 'DROP ' || obj.object_type || ' ' || obj.object_name;
            END IF;

            EXECUTE IMMEDIATE v_sql;
            DBMS_OUTPUT.PUT_LINE('Successfully dropped ' || obj.object_type || ': ' || obj.object_name);
        EXCEPTION
            WHEN OTHERS THEN
                DBMS_OUTPUT.PUT_LINE('Skipped ' || obj.object_type || ' ' || obj.object_name || ' - ' || SQLERRM);
        END;
    END LOOP;
    
    DBMS_OUTPUT.PUT_LINE('------------------------------------------------');
    DBMS_OUTPUT.PUT_LINE('Cleanup completed successfully! Starting schema creation...');
END;
/

-- =============================================================================
-- PART 2: DATABASE SETUP SCRIPT (DDL)
-- =============================================================================

--------------------------------------------------------------------------------
-- 01. sufioun_COMPANY
-- Stores mother company information
--------------------------------------------------------------------------------
CREATE TABLE sufioun_company (
    company_id          VARCHAR2(50) PRIMARY KEY,
    company_name        VARCHAR2(200) NOT NULL UNIQUE,
    company_proprietor  VARCHAR2(200),
    phone_no            VARCHAR2(50) NOT NULL UNIQUE,
    email               VARCHAR2(200) NOT NULL UNIQUE,
    address             VARCHAR2(300),
    website             VARCHAR2(200) UNIQUE,
    contact_person      VARCHAR2(200),
    cp_designation      VARCHAR2(200),
    cp_phone_no         VARCHAR2(50),
    tag_line            VARCHAR2(300),
    mission_vision      VARCHAR2(1000),
    -- APEX Image Columns
    image_name          VARCHAR2(500),
    image_mime_type     VARCHAR2(100),
    image_blob          BLOB,
    --
    status              NUMBER,
    cre_by              VARCHAR2(100),
    cre_dt              DATE,
    upd_by              VARCHAR2(100),
    upd_dt              DATE
)
LOB (image_blob) STORE AS (
    TABLESPACE USERS
    ENABLE STORAGE IN ROW
    CHUNK 8192
    PCTVERSION 10
    CACHE
    COMPRESS HIGH
);
 COMMENT ON TABLE sufioun_company IS 'Mother Company Information Table';
/

CREATE SEQUENCE sufioun_company_seq START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;

CREATE OR REPLACE TRIGGER sufioun_trg_company_bi
BEFORE INSERT OR UPDATE ON sufioun_company FOR EACH ROW
DECLARE v_seq NUMBER; v_code VARCHAR2(100);
BEGIN
    IF INSERTING AND :NEW.company_id IS NULL THEN
        v_seq := sufioun_company_seq.NEXTVAL;
        v_code := UPPER(SUBSTR(TRIM(:NEW.company_name),1,3));
        :NEW.company_id := NVL(v_code, 'COM') || TO_CHAR(v_seq);
    END IF;
    IF INSERTING THEN
        IF :NEW.status IS NULL THEN :NEW.status := 1; END IF;
        IF :NEW.cre_by IS NULL THEN :NEW.cre_by := USER; END IF;
        IF :NEW.cre_dt IS NULL THEN :NEW.cre_dt := SYSDATE; END IF;
    ELSIF UPDATING THEN
        :NEW.upd_by := USER;
        :NEW.upd_dt := SYSDATE;
    END IF;
END;
/

--------------------------------------------------------------------------------
-- 02. sufioun_BRANCHES
-- Branch master under mother company
--------------------------------------------------------------------------------
CREATE TABLE sufioun_branches (
  branch_id       VARCHAR2(50) PRIMARY KEY,
  company_id      VARCHAR2(50) NOT NULL,
  branch_code     VARCHAR2(50) NOT NULL UNIQUE,
  branch_name     VARCHAR2(200) NOT NULL,
  phone_no        VARCHAR2(50) UNIQUE,
  email           VARCHAR2(200) UNIQUE,
  address         VARCHAR2(300),
  location        VARCHAR2(200),
  is_hq           NUMBER(1) DEFAULT 0 CHECK (is_hq IN (0, 1)),
    -- APEX Image Columns
    image_name      VARCHAR2(500),
    image_mime_type VARCHAR2(100),
    image_blob      BLOB,
    --
  status          NUMBER(1) DEFAULT 1 CHECK (status IN (0, 1)),
  cre_by          VARCHAR2(100),
  cre_dt          DATE,
  upd_by          VARCHAR2(100),
  upd_dt          DATE,
  CONSTRAINT sufioun_fk_branch_company FOREIGN KEY (company_id) REFERENCES sufioun_company(company_id),
  CONSTRAINT sufioun_uk_branch_name UNIQUE (company_id, branch_name)
);
 COMMENT ON TABLE sufioun_branches IS 'Branch Master Data';
/

CREATE SEQUENCE sufioun_branches_seq START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;

CREATE OR REPLACE TRIGGER sufioun_trg_branches_bi
BEFORE INSERT OR UPDATE ON sufioun_branches FOR EACH ROW
DECLARE
  v_seq NUMBER;
  v_code VARCHAR2(100);
BEGIN
  IF INSERTING AND :NEW.branch_id IS NULL THEN
    v_seq := sufioun_branches_seq.NEXTVAL;
    IF :NEW.branch_code IS NOT NULL THEN
      :NEW.branch_id := UPPER(TRIM(:NEW.branch_code));
    ELSE
      v_code := UPPER(SUBSTR(TRIM(:NEW.branch_name), 1, 3));
      :NEW.branch_id := NVL(v_code, 'BRN') || '-' || LPAD(v_seq, 2, '0');
    END IF;
  END IF;

  IF INSERTING THEN
    IF :NEW.status IS NULL THEN :NEW.status := 1; END IF;
    IF :NEW.cre_by IS NULL THEN :NEW.cre_by := USER; END IF;
    IF :NEW.cre_dt IS NULL THEN :NEW.cre_dt := SYSDATE; END IF;
  ELSIF UPDATING THEN
    :NEW.upd_by := USER;
    :NEW.upd_dt := SYSDATE;
  END IF;
END;
/

