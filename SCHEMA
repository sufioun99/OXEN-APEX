  case
    when dbms_lob.getlength(e.photo) > 0 then
      'f?p='||v('APP_ID')||':0:'||v('APP_SESSION')||':APPLICATION_PROCESS=EMP_PHOTO:::&x01='||e.employee_id
    else
      '#APP_FILES#avatar-default.png'
  end img_url,

  apex_page.get_url(
    p_page   => 15,
    p_items  => 'P15_EMPLOYEE_ID',
    p_values => e.employee_id
  ) cv_url

from sufioun_employees e
left join sufioun_jobs j on j.job_id = e.job_id
left join sufioun_departments d on d.department_id = e.department_id;
--19)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_V_EMP_DIRECTORY" ("EMPLOYEE_ID", "FIRST_NAME", "LAST_NAME", "EMPLOYEE_NAME", "EMAIL", "PHONE_NO", "HIRE_DATE", "SALARY", "STATUS", "DEPARTMENT_ID", "JOB_ID", "JOB_TITLE", "DEPARTMENT_NAME", "STATUS_LABEL", "STATUS_COLOR", "IMG_URL", "CV_URL") AS 
