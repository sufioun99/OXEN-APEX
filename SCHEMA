--ALL VIEWS FOR REPORTS

--1)SUFIOUN_DASH_KPI_V

  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_DASH_KPI_V" ("METRIC_NAME", "METRIC_VALUE", "ICON_CLASS", "COLOR_CLASS") AS 
  SELECT 'Total Customers' metric_name,
       TO_CHAR(COUNT(*)) metric_value,
       'fa fa-users' icon_class,
       'u-color-1' color_class
FROM sufioun_customers WHERE status = 1

UNION ALL
SELECT 'Current Month Sales',
       TO_CHAR(NVL(SUM(grand_total), 0), 'FML999,999,999.00'),
       'fa fa-money-bill' ,
       'u-color-2'
FROM sufioun_sales_master
WHERE TRUNC(invoice_date,'MM') = TRUNC(SYSDATE,'MM') AND status = 1

UNION ALL
SELECT 'Total Active Employees',
       TO_CHAR(COUNT(*)),
       'fa fa-id-badge',
       'u-color-3'
FROM sufioun_employees WHERE status = 1

UNION ALL
SELECT 'Items in Stock',
       TO_CHAR(NVL(SUM(quantity), 0)),
       'fa fa-cubes',
       'u-color-4'
FROM sufioun_stock

UNION ALL
SELECT 'Low Stock Items (< 20)',
       TO_CHAR(COUNT(*)),
       'fa fa-exclamation-triangle',
       'u-color-5'
FROM sufioun_stock
WHERE NVL(quantity,0) < 20

UNION ALL
SELECT 'Out of Stock',
       TO_CHAR(COUNT(*)),
       'fa fa-ban',
       'u-color-6'
FROM sufioun_stock
WHERE NVL(quantity,0) = 0;

--2)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_DASH_LOW_STOCK_V" ("PRODUCT_NAME", "QUANTITY", "SUPPLIER_NAME", "QTY_CLASS") AS 
  SELECT 
  p.product_name,
  s.quantity,
  sup.supplier_name,
  CASE 
    WHEN NVL(s.quantity,0) <= 5 THEN 'badge-danger'
    WHEN NVL(s.quantity,0) <= 10 THEN 'badge-warn'
    ELSE 'badge-info'
  END AS qty_class
FROM sufioun_stock s
JOIN sufioun_products p ON p.product_id = s.product_id
JOIN sufioun_suppliers sup ON sup.supplier_id = p.supplier_id
WHERE NVL(s.quantity,0) < 20
ORDER BY s.quantity ASC;
--3)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_DASH_PAYABLES_BREAKDOWN_V" ("LABEL", "VAL") AS 
  SELECT 'Paid' label, NVL(SUM(NVL(pay_total,0)),0) val
FROM sufioun_suppliers WHERE status=1
UNION ALL
SELECT 'Due' label, NVL(SUM(NVL(due,0)),0) val
FROM sufioun_suppliers WHERE status=1;
--4)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_DASH_PAYABLES_KPI_V" ("METRIC_NAME", "METRIC_VALUE", "ICON_CLASS", "COLOR_CLASS") AS 
  SELECT
  'Total Payable Due' AS metric_name,
  TO_CHAR(NVL(SUM(NVL(due,0)),0), 'FML999,999,999,990.00') AS metric_value,
  'fa fa-hand-holding-dollar' AS icon_class,
  'u-color-6' AS color_class
FROM sufioun_suppliers
WHERE status = 1

UNION ALL
SELECT
  'Suppliers with Due' AS metric_name,
  TO_CHAR(COUNT(*)) AS metric_value,
  'fa fa-truck' AS icon_class,
  'u-color-5' AS color_class
FROM sufioun_suppliers
WHERE status = 1
  AND NVL(due,0) > 0

UNION ALL
SELECT
  'Total Purchased' AS metric_name,
  TO_CHAR(NVL(SUM(NVL(purchase_total,0)),0), 'FML999,999,999,990.00') AS metric_value,
  'fa fa-cart-shopping' AS icon_class,
  'u-color-4' AS color_class
FROM sufioun_suppliers
WHERE status = 1

UNION ALL
SELECT
  'Total Paid' AS metric_name,
  TO_CHAR(NVL(SUM(NVL(pay_total,0)),0), 'FML999,999,999,990.00') AS metric_value,
  'fa fa-credit-card' AS icon_class,
  'u-color-3' AS color_class
FROM sufioun_suppliers
WHERE status = 1;
--5)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_DASH_RECENT_SALES_V" ("INVOICE_ID", "INVOICE_DATE", "GRAND_TOTAL", "CUSTOMER_ID", "SALES_BY") AS 
  SELECT "INVOICE_ID","INVOICE_DATE","GRAND_TOTAL","CUSTOMER_ID","SALES_BY"
FROM (
    SELECT
        invoice_id,
        invoice_date,
        grand_total,
        customer_id,
        sales_by
    FROM sufioun_sales_master
    WHERE status = 1
    ORDER BY invoice_date DESC, invoice_id DESC
)
WHERE ROWNUM <= 10;
--6)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_DASH_SALES_TREND_V" ("MONTH_START", "MONTH_LABEL", "TOTAL_SALES") AS 
  WITH mx AS (
  SELECT MAX(invoice_date) AS max_dt
  FROM sufioun_sales_master
  WHERE status = 1
),
months AS (
  SELECT ADD_MONTHS(TRUNC(mx.max_dt,'MM'), -11) + NUMTOYMINTERVAL(LEVEL-1,'MONTH') AS month_start
  FROM mx
  CONNECT BY LEVEL <= 12
)
SELECT
  m.month_start,
  TO_CHAR(m.month_start,'Mon YYYY') AS month_label,
  NVL(SUM(s.grand_total),0) AS total_sales
FROM months m
LEFT JOIN sufioun_sales_master s
  ON TRUNC(s.invoice_date,'MM') = m.month_start
 AND s.status = 1
GROUP BY m.month_start
ORDER BY m.month_start;
--7)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_DASH_SERVICE_TREND_V" ("MONTH_START", "MONTH_LABEL", "SERVICE_JOBS", "SERVICE_REVENUE") AS 
  WITH mx AS (
  SELECT MAX(service_date) AS max_dt
  FROM sufioun_service_master
  WHERE status = 1
),
base AS (
  SELECT ADD_MONTHS(TRUNC(mx.max_dt,'MM'), -11) AS start_dt,
         TRUNC(mx.max_dt,'MM') AS end_dt
  FROM mx
),
months AS (
  SELECT ADD_MONTHS((SELECT start_dt FROM base), LEVEL-1) AS month_start
  FROM dual
  CONNECT BY LEVEL <= 12
)
SELECT
  m.month_start,
  TO_CHAR(m.month_start, 'Mon YYYY') AS month_label,
  COUNT(s.service_id) AS service_jobs,
  NVL(SUM(NVL(s.grand_total,0)),0) AS service_revenue
FROM months m
LEFT JOIN sufioun_service_master s
  ON TRUNC(s.service_date,'MM') = m.month_start
 AND s.status = 1
GROUP BY m.month_start
ORDER BY m.month_start;
--8)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_DASH_STOCK_CAT_V" ("CATEGORY_NAME", "TOTAL_STOCK") AS 
  SELECT 
    c.product_cat_name AS category_name, 
    NVL(SUM(s.quantity), 0) AS total_stock
FROM sufioun_product_categories c
LEFT JOIN sufioun_stock s ON c.product_cat_id = s.product_cat_id
WHERE c.status = 1
GROUP BY c.product_cat_name;
--9)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_DASH_TOP_DUE_SUPPLIERS_V" ("SUPPLIER_NAME", "PHONE_NO", "DUE") AS 
  SELECT "SUPPLIER_NAME","PHONE_NO","DUE"
FROM (
  SELECT
    supplier_name,
    phone_no,
    NVL(due,0) AS due
  FROM sufioun_suppliers
  WHERE status = 1
    AND NVL(due,0) > 0
  ORDER BY NVL(due,0) DESC
)
WHERE ROWNUM <= 10;
--10)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_DASH_TOP_STOCK_PRODUCTS_V" ("PRODUCT_NAME", "QTY") AS 
  SELECT "PRODUCT_NAME","QTY"
FROM (
    SELECT
        p.product_name,
        SUM(NVL(s.quantity,0)) AS qty
    FROM sufioun_stock s
    JOIN sufioun_products p ON p.product_id = s.product_id
    GROUP BY p.product_name
    ORDER BY qty DESC
)
WHERE ROWNUM <= 5;
--11)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_DEPT_EMP_REPORT_V" ("DEPARTMENT_NAME", "DEPARTMENT_ID", "EMPLOYEE_ID", "EMPLOYEE_NAME", "EMAIL", "PHONE_NO", "HIRE_DATE", "SALARY", "JOB_TITLE", "MANAGER_NAME", "DEPT_STATUS", "EMP_STATUS") AS 
  SELECT 
    d.department_name,
    d.department_id,
    e.employee_id,
    e.first_name || ' ' || e.last_name AS employee_name,
    e.email,
    e.phone_no,
    e.hire_date,
    e.salary,
    j.job_title,
    m.first_name || ' ' || m.last_name AS manager_name,
    d.status AS dept_status,
    e.status AS emp_status
FROM sufioun_departments d
LEFT JOIN sufioun_employees e ON d.department_id = e.department_id
LEFT JOIN sufioun_jobs j ON e.job_id = j.job_id
LEFT JOIN sufioun_employees m ON e.manager_id = m.employee_id
WHERE d.status = 1 
  AND (e.status = 1 OR e.status IS NULL) -- Only fetch active departments and active employees
ORDER BY d.department_name, e.first_name;
--12)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_REORDER_REPORT_V" ("PRODUCT_CODE", "PRODUCT_NAME", "CATEGORY_NAME", "SUPPLIER_NAME", "QUANTITY", "STOCK_STATUS") AS 
  SELECT
  product_code,
  product_name,
  category_name,
  supplier_name,
  quantity,
  CASE
    WHEN quantity = 0 THEN 'OUT OF STOCK'
    WHEN quantity < 10 THEN 'CRITICAL'
    WHEN quantity < 20 THEN 'LOW'
    ELSE 'OK'
  END AS stock_status
FROM sufioun_stock_position_v
WHERE quantity < 20
ORDER BY quantity ASC;
--13)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_SALES_INVOICES_REPORT_V" ("INVOICE_ID", "INVOICE_DATE", "CUSTOMER_ID", "CUSTOMER_NAME", "SALES_BY", "SALES_BY_NAME", "TOTAL_AMOUNT", "VAT", "DISCOUNT", "GRAND_TOTAL") AS 
  SELECT
  s.invoice_id,
  s.invoice_date,
  s.customer_id,
  c.customer_name,
  s.sales_by,
  e.first_name || ' ' || e.last_name AS sales_by_name,
  s.total_amount,
  s.vat,
  s.discount,
  s.grand_total
FROM sufioun_sales_master s
LEFT JOIN sufioun_customers c ON c.customer_id = s.customer_id
LEFT JOIN sufioun_employees e ON e.employee_id = s.sales_by
WHERE s.status = 1;
--14)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_SALES_MONTHLY_SUMMARY_V" ("MONTH_START", "MONTH_LABEL", "INVOICES", "TOTAL_SALES", "TOTAL_VAT", "TOTAL_DISCOUNT") AS 
  SELECT
  TRUNC(invoice_date,'MM') AS month_start,
  TO_CHAR(TRUNC(invoice_date,'MM'),'Mon YYYY') AS month_label,
  COUNT(*) AS invoices,
  SUM(NVL(grand_total,0)) AS total_sales,
  SUM(NVL(vat,0)) AS total_vat,
  SUM(NVL(discount,0)) AS total_discount
FROM sufioun_sales_master
WHERE status = 1
GROUP BY TRUNC(invoice_date,'MM')
ORDER BY TRUNC(invoice_date,'MM') DESC;
--15)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_SERVICE_JOBS_REPORT_V" ("SERVICE_ID", "SERVICE_DATE", "CUSTOMER_ID", "CUSTOMER_NAME", "SERVICE_BY", "SERVICE_BY_NAME", "INVOICE_ID", "WARRANTY_APPLICABLE", "SERVICE_CHARGE_TOTAL", "TOTAL_PRICE", "VAT", "GRAND_TOTAL") AS 
  SELECT
  sm.service_id,
  sm.service_date,
  sm.customer_id,
  c.customer_name,
  sm.service_by,
  e.first_name || ' ' || e.last_name AS service_by_name,
  sm.invoice_id,
  sm.warranty_applicable,
  sm.service_charge_total,
  sm.total_price,
  sm.vat,
  sm.grand_total
FROM sufioun_service_master sm
LEFT JOIN sufioun_customers c ON c.customer_id = sm.customer_id
LEFT JOIN sufioun_employees e ON e.employee_id = sm.service_by
WHERE sm.status = 1;
--16)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_STOCK_POSITION_V" ("PRODUCT_ID", "PRODUCT_CODE", "PRODUCT_NAME", "CATEGORY_NAME", "SUPPLIER_NAME", "QUANTITY", "MRP", "PURCHASE_PRICE", "STOCK_VALUE_COST", "STOCK_VALUE_MRP") AS 
  SELECT
  p.product_id,
  p.product_code,
  p.product_name,
  cat.product_cat_name AS category_name,
  sup.supplier_name,
  NVL(s.quantity,0) AS quantity,
  p.mrp,
  p.purchase_price,
  (NVL(s.quantity,0) * NVL(p.purchase_price,0)) AS stock_value_cost,
  (NVL(s.quantity,0) * NVL(p.mrp,0)) AS stock_value_mrp
FROM sufioun_products p
LEFT JOIN sufioun_stock s ON s.product_id = p.product_id
LEFT JOIN sufioun_product_categories cat ON cat.product_cat_id = p.category_id
LEFT JOIN sufioun_suppliers sup ON sup.supplier_id = p.supplier_id
WHERE NVL(p.status,1) = 1;
--17)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_SUPPLIER_PAYABLES_REPORT_V" ("SUPPLIER_ID", "SUPPLIER_NAME", "PHONE_NO", "PURCHASE_TOTAL", "PAY_TOTAL", "DUE", "DUE_RISK") AS 
  SELECT
  supplier_id,
  supplier_name,
  phone_no,
  purchase_total,
  pay_total,
  NVL(due,0) AS due,
  CASE
    WHEN NVL(due,0) = 0 THEN 'CLEAR'
    WHEN NVL(due,0) < 5000 THEN 'LOW'
    WHEN NVL(due,0) < 50000 THEN 'MEDIUM'
    ELSE 'HIGH'
  END AS due_risk
FROM sufioun_suppliers
WHERE status = 1;
--18)
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "SUFIOUN_V_EMP_DIR" ("EMPLOYEE_ID", "EMPLOYEE_NAME", "EMAIL", "PHONE_NO", "SALARY", "STATUS", "DEPARTMENT_ID", "JOB_TITLE", "DEPARTMENT_NAME", "STATUS_LABEL", "STATUS_COLOR", "IMG_URL", "CV_URL") AS 
