        IF :OLD.product_id != :NEW.product_id THEN
            sufioun_update_stock_qty(:OLD.product_id, NVL(:OLD.return_quantity, 0));
            sufioun_update_stock_qty(:NEW.product_id, -NVL(:NEW.return_quantity, 0));
        ELSE
            sufioun_update_stock_qty(:NEW.product_id, -(NVL(:NEW.return_quantity, 0) - NVL(:OLD.return_quantity, 0)));
        END IF;
    END IF;
END;
/

CREATE OR REPLACE TRIGGER sufioun_trg_auto_stock_damage
AFTER INSERT OR UPDATE OR DELETE ON sufioun_damage_detail
FOR EACH ROW
BEGIN
    IF INSERTING THEN
        sufioun_update_stock_qty(:NEW.product_id, -:NEW.damage_quantity);
    ELSIF DELETING THEN
        sufioun_update_stock_qty(:OLD.product_id, :OLD.damage_quantity);
    ELSIF UPDATING THEN
        IF :OLD.product_id != :NEW.product_id THEN
            sufioun_update_stock_qty(:OLD.product_id, :OLD.damage_quantity);
            sufioun_update_stock_qty(:NEW.product_id, -:NEW.damage_quantity);
        ELSE
            sufioun_update_stock_qty(:NEW.product_id, -(:NEW.damage_quantity - :OLD.damage_quantity));
        END IF;
    END IF;
END;
/

CREATE OR REPLACE TRIGGER sufioun_trg_sync_prod_to_stk
AFTER UPDATE OF supplier_id, category_id, sub_cat_id ON sufioun_products
FOR EACH ROW
BEGIN
    UPDATE sufioun_stock 
    SET supplier_id = :NEW.supplier_id,
        product_cat_id = :NEW.category_id,
        sub_cat_id = :NEW.sub_cat_id
    WHERE product_id = :NEW.product_id;
END;
/

