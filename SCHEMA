--------------------------------------------------------------------------------
-- sufioun_SUPPLIERS_PAY_TOTAL (COMPOUND TRIGGER)
--------------------------------------------------------------------------------
CREATE OR REPLACE TRIGGER sufioun_trg_sup_pay_total
FOR INSERT OR UPDATE OR DELETE ON sufioun_payments
COMPOUND TRIGGER
  TYPE t_supplier IS TABLE OF sufioun_payments.supplier_id%TYPE;
  g_suppliers t_supplier := t_supplier();
  BEFORE EACH ROW IS
  BEGIN
    IF INSERTING OR UPDATING OR DELETING THEN
      g_suppliers.EXTEND;
      g_suppliers(g_suppliers.COUNT) := :NEW.supplier_id;
    END IF;
  END BEFORE EACH ROW;
  AFTER STATEMENT IS
  BEGIN
    FOR i IN 1 .. g_suppliers.COUNT LOOP
      BEGIN
        UPDATE sufioun_suppliers s
        SET s.pay_total = NVL((SELECT SUM(amount)
                               FROM sufioun_payments
                               WHERE supplier_id = g_suppliers(i)), 0)
        WHERE s.supplier_id = g_suppliers(i);
      EXCEPTION
        WHEN NO_DATA_FOUND THEN NULL;
      END;
    END LOOP;
  END AFTER STATEMENT;
END;
/

