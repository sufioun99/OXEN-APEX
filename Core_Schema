CREATE OR REPLACE TRIGGER sufioun_trg_sales_detail_sync
FOR INSERT OR UPDATE OR DELETE ON sufioun_sales_details
COMPOUND TRIGGER
  TYPE t_inv_list IS TABLE OF BOOLEAN INDEX BY sufioun_sales_details.invoice_id%TYPE;
  v_inv_ids t_inv_list;
  v_idx sufioun_sales_details.invoice_id%TYPE;
  AFTER EACH ROW IS
  BEGIN
    IF INSERTING OR UPDATING THEN
       v_inv_ids(:NEW.invoice_id) := TRUE;
    ELSIF DELETING THEN
       v_inv_ids(:OLD.invoice_id) := TRUE;
    END IF;
  END AFTER EACH ROW;
  AFTER STATEMENT IS
    v_total        NUMBER;
    v_grand_total  NUMBER;
    v_discount     NUMBER;
    v_vat_pct      NUMBER;
    v_adj_amount   NUMBER;
  BEGIN
    v_idx := v_inv_ids.FIRST;
    WHILE v_idx IS NOT NULL LOOP
      SELECT NVL(SUM(mrp * quantity), 0)
      INTO v_total
      FROM sufioun_sales_details
      WHERE invoice_id = v_idx;

      SELECT NVL(discount, 0), NVL(vat, 0), NVL(adjust_amount, 0)
      INTO v_discount, v_vat_pct, v_adj_amount
      FROM sufioun_sales_master
      WHERE invoice_id = v_idx;

      v_grand_total := (v_total - v_discount - v_adj_amount) * (1 + v_vat_pct/100);

      UPDATE sufioun_sales_master
      SET total_amount = v_total,
          grand_total  = ROUND(v_grand_total, 2),
          upd_by       = USER,
          upd_dt       = SYSDATE
      WHERE invoice_id = v_idx;

      v_idx := v_inv_ids.NEXT(v_idx);
    END LOOP;
  END AFTER STATEMENT;
END sufioun_trg_sales_detail_sync;
/

