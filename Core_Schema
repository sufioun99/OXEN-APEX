CREATE TABLE sufioun_com_users (
    user_id     VARCHAR2(50) PRIMARY KEY,
    user_name   VARCHAR2(100) NOT NULL UNIQUE,
    password    VARCHAR2(200) NOT NULL,
    role        VARCHAR2(50) DEFAULT 'user' NOT NULL,
    employee_id VARCHAR2(50),
    last_login  DATE,
    is_online   NUMBER(1) DEFAULT 0,
    -- APEX Image Columns
    image_name      VARCHAR2(500),
    image_mime_type VARCHAR2(100),
    image_blob      BLOB,
    --
    status      NUMBER(1) DEFAULT 1 CHECK (status IN (0, 1)),
    cre_by      VARCHAR2(100),
    cre_dt      DATE,
    upd_by      VARCHAR2(100),
    upd_dt      DATE,
    CONSTRAINT sufioun_fk_users_emp FOREIGN KEY (employee_id) REFERENCES sufioun_employees(employee_id) ON DELETE SET NULL,
