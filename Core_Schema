--------------------------------------------------------------------------------
-- 01. sufioun_COMPANY
-- Stores mother company information
--------------------------------------------------------------------------------
CREATE TABLE sufioun_company (
    company_id          VARCHAR2(50) PRIMARY KEY,
    company_name        VARCHAR2(200) NOT NULL UNIQUE,
    company_proprietor  VARCHAR2(200),
    phone_no            VARCHAR2(50) NOT NULL UNIQUE,
    email               VARCHAR2(200) NOT NULL UNIQUE,
    address             VARCHAR2(300),
    website             VARCHAR2(200) UNIQUE,
    contact_person      VARCHAR2(200),
    cp_designation      VARCHAR2(200),
    cp_phone_no         VARCHAR2(50),
    tag_line            VARCHAR2(300),
    mission_vision      VARCHAR2(1000),
    -- APEX Image Columns
    image_name          VARCHAR2(500),
    image_mime_type     VARCHAR2(100),
    image_blob          BLOB,
    --
    status              NUMBER,
    cre_by              VARCHAR2(100),
    cre_dt              DATE,
    upd_by              VARCHAR2(100),
    upd_dt              DATE
)
LOB (image_blob) STORE AS (
    ENABLE STORAGE IN ROW
    CHUNK 8192
    PCTVERSION 10
    CACHE
    COMPRESS HIGH
);
/

CREATE SEQUENCE sufioun_company_seq START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;

CREATE OR REPLACE TRIGGER sufioun_trg_company_bi
BEFORE INSERT OR UPDATE ON sufioun_company FOR EACH ROW
DECLARE v_seq NUMBER; v_code VARCHAR2(100);
BEGIN
    IF INSERTING AND :NEW.company_id IS NULL THEN
        v_seq := sufioun_company_seq.NEXTVAL;
        v_code := UPPER(SUBSTR(TRIM(:NEW.company_name),1,3));
        :NEW.company_id := NVL(v_code, 'COM') || TO_CHAR(v_seq);
    END IF;
    IF INSERTING THEN
        IF :NEW.status IS NULL THEN :NEW.status := 1; END IF;
        IF :NEW.cre_by IS NULL THEN :NEW.cre_by := USER; END IF;
        IF :NEW.cre_dt IS NULL THEN :NEW.cre_dt := SYSDATE; END IF;
    ELSIF UPDATING THEN
        :NEW.upd_by := USER;
        :NEW.upd_dt := SYSDATE;
    END IF;
END;
/

--------------------------------------------------------------------------------
-- 02. sufioun_BRANCHES
-- Branch master under mother company
--------------------------------------------------------------------------------
CREATE TABLE sufioun_branches (
  branch_id       VARCHAR2(50) PRIMARY KEY,
  company_id      VARCHAR2(50) NOT NULL,
  branch_code     VARCHAR2(50) NOT NULL UNIQUE,
  branch_name     VARCHAR2(200) NOT NULL,
  phone_no        VARCHAR2(50) UNIQUE,
  email           VARCHAR2(200) UNIQUE,
  address         VARCHAR2(300),
  location        VARCHAR2(200),
  is_hq           NUMBER(1) DEFAULT 0 CHECK (is_hq IN (0, 1)),
    -- APEX Image Columns
    image_name      VARCHAR2(500),
    image_mime_type VARCHAR2(100),
    image_blob      BLOB,
    --
  status          NUMBER(1) DEFAULT 1 CHECK (status IN (0, 1)),
  cre_by          VARCHAR2(100),
  cre_dt          DATE,
  upd_by          VARCHAR2(100),
  upd_dt          DATE,
  CONSTRAINT sufioun_fk_branch_company FOREIGN KEY (company_id) REFERENCES sufioun_company(company_id),
  CONSTRAINT sufioun_uk_branch_name UNIQUE (company_id, branch_name)
);
/

CREATE SEQUENCE sufioun_branches_seq START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;

CREATE OR REPLACE TRIGGER sufioun_trg_branches_bi
BEFORE INSERT OR UPDATE ON sufioun_branches FOR EACH ROW
DECLARE
  v_seq NUMBER;
  v_code VARCHAR2(100);
BEGIN
  IF INSERTING AND :NEW.branch_id IS NULL THEN
    v_seq := sufioun_branches_seq.NEXTVAL;
    IF :NEW.branch_code IS NOT NULL THEN
      :NEW.branch_id := UPPER(TRIM(:NEW.branch_code));
    ELSE
      v_code := UPPER(SUBSTR(TRIM(:NEW.branch_name), 1, 3));
      :NEW.branch_id := NVL(v_code, 'BRN') || '-' || LPAD(v_seq, 2, '0');
    END IF;
  END IF;

  IF INSERTING THEN
    IF :NEW.status IS NULL THEN :NEW.status := 1; END IF;
    IF :NEW.cre_by IS NULL THEN :NEW.cre_by := USER; END IF;
    IF :NEW.cre_dt IS NULL THEN :NEW.cre_dt := SYSDATE; END IF;
  ELSIF UPDATING THEN
    :NEW.upd_by := USER;
    :NEW.upd_dt := SYSDATE;
  END IF;
END;
/

