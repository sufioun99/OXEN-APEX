-- 29. sufioun_EXPENSE_MASTER
--------------------------------------------------------------------------------
CREATE TABLE sufioun_expense_master (
    expense_id      VARCHAR2(50) PRIMARY KEY,
    expense_no      VARCHAR2(50) UNIQUE,
    expense_date    DATE,
    expense_type_id VARCHAR2(50),
  department_id   VARCHAR2(50),
    expense_by      VARCHAR2(100),
    expense_total   NUMBER(15,2),
    notes           VARCHAR2(1000),
    -- APEX Image Columns
    image_name      VARCHAR2(500),
    image_mime_type VARCHAR2(100),
    image_blob      BLOB,
    --
    status          NUMBER(1) DEFAULT 1 CHECK (status IN (0, 1)),
    cre_by          VARCHAR2(100),
    cre_dt          DATE,
    upd_by          VARCHAR2(100),
    upd_dt          DATE,
    CONSTRAINT sufioun_fk_ex_mst FOREIGN KEY (expense_type_id) REFERENCES sufioun_expense_list(expense_type_id),
    CONSTRAINT sufioun_fk_ex_dept FOREIGN KEY (department_id) REFERENCES sufioun_departments(department_id)
);
/

CREATE SEQUENCE sufioun_exp_mst_seq START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;

CREATE OR REPLACE TRIGGER sufioun_trg_exp_mst_bi BEFORE INSERT OR UPDATE ON sufioun_expense_master FOR EACH ROW
BEGIN
    IF INSERTING AND :NEW.expense_id IS NULL THEN
        :NEW.expense_id := 'EXM' || TO_CHAR(sufioun_exp_mst_seq.NEXTVAL); 
    END IF;
    IF INSERTING THEN
        IF :NEW.status IS NULL THEN :NEW.status := 1; END IF;
        IF :NEW.cre_by IS NULL THEN :NEW.cre_by := USER; END IF;
        IF :NEW.cre_dt IS NULL THEN :NEW.cre_dt := SYSDATE; END IF;
    ELSIF UPDATING THEN
        :NEW.upd_by := USER; :NEW.upd_dt := SYSDATE;
    END IF;
END;
/

