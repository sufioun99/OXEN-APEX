CREATE SEQUENCE sufioun_exp_det_seq START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;

CREATE OR REPLACE TRIGGER sufioun_trg_exp_det_bi BEFORE INSERT OR UPDATE ON sufioun_expense_details FOR EACH ROW
BEGIN 
    IF INSERTING AND :NEW.expense_det_id IS NULL THEN
        :NEW.expense_det_id := 'EXD' || TO_CHAR(sufioun_exp_det_seq.NEXTVAL);
    END IF; 
END;
/

CREATE OR REPLACE TRIGGER sufioun_tri_expense_total
AFTER INSERT OR UPDATE OR DELETE ON sufioun_expense_details
BEGIN
   FOR r IN (SELECT DISTINCT expense_id FROM sufioun_expense_details) LOOP
      UPDATE sufioun_expense_master m
      SET m.expense_total = (SELECT NVL(SUM(d.amount), 0) FROM sufioun_expense_details d WHERE d.expense_id = r.expense_id)
      WHERE m.expense_id = r.expense_id;
   END LOOP;
END;
/

