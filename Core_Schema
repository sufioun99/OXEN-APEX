    description       VARCHAR2(1000),
    amount            NUMBER(15,2) DEFAULT 0,
    -- APEX Image Columns
    image_name      VARCHAR2(500),
    image_mime_type VARCHAR2(100),
    image_blob      BLOB,
    --
    CONSTRAINT sufioun_fk_ex_det_mst FOREIGN KEY (expense_id) REFERENCES sufioun_expense_master(expense_id)
);
